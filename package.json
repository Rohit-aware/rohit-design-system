{
  "name": "@rohit/design-system",
  "version": "1.0.0",
  "description": "Production-ready React Native design system SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "build:esm": "tsc --outDir dist --module esnext --declaration",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run type-check"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-native": ">=0.72.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react-native",
    "design-system",
    "design-tokens"
  ],
  "author": "Rohit Aware",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rohit-aware/rohit-design-system"
  }
}
